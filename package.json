{
  "name": "playwrightcursor",
  "version": "1.0.0",
  "description": "Industry-style Playwright TypeScript framework using CommonJS and POM.",
  "main": "index.ts",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test tests/smoke",
    "test:regression": "playwright test tests/regression",
    "test:tag:smoke": "playwright test --grep @smoke",
    "test:tag:regression": "playwright test --grep @regression",
    "test:headed": "playwright test --headed",
    "test:headless": "cross-env HEADLESS=true SLOW_MO_MS=0 playwright test",
    "report": "playwright show-report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "cross-env": "^10.1.0"
  }
}
